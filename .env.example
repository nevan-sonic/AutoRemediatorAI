# Groq API Configuration
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# MongoDB Configuration
MONGODB_URI=your_mongodb_atlas_uri_here
MONGODB_DB_NAME=autoremediator

# Observability Configuration (Set to localhost for local run, docker DNS inside docker compose)
PROMETHEUS_URL=http://prometheus:9090
LOKI_URL=http://loki:3100
JAEGER_URL=http://jaeger:16686

# Telemetry and Monitored Services
MONITORED_SERVICES=payment-service,inventory-service,order-service
LATENCY_THRESHOLD_MS=2000

# Safety Configuration
MIN_CONFIDENCE=0.70
PROTECTED_SERVICES=
COOLDOWN_SECONDS=300
MAX_BLAST_RADIUS=3
VALIDATION_WAIT_SECONDS=60

# FastAPI Configuration
ALLOWED_ORIGINS=http://localhost:3000
DEMO_MODE=false
